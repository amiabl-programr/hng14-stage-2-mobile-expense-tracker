{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl" : ".",
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@components/*": ["src/components/*"],
      "@store/*": ["src/store/*"],
      "@utils/*": ["src/utils/*"],
      "@hooks/*": ["src/hooks/*"],
      "@screens/*": ["src/screens/*"],
      "@constants/*": ["src/constants/*"],
      "@services/*": ["src/services/*"],
      "@app-types/*": ["src/types/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
